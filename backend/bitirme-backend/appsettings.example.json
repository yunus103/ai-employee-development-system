{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=bitirme_db;Username=YOUR_USER;Password=YOUR_PASSWORD"
  },
  "Jwt": {
    "Secret": "YOUR_JWT_SECRET_MIN_32_CHARS_HERE",
    "Issuer": "BitirmeBackend",
    "Audience": "BitirmeBackendClient",
    "AccessTokenExpirationMinutes": 60,
    "RefreshTokenExpirationDays": 7
  },
  "MlService": {
    "BaseUrl": "http://localhost:8001",
    "TimeoutSeconds": 30,
    "CircuitBreakerFailureThreshold": 3,
    "CircuitBreakerDurationSeconds": 60
  },
  "AllowedOrigins": "http://localhost:3000",
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  },
  "AllowedHosts": "*",
  "_note": "Set ASPNETCORE_ENVIRONMENT=Production for production deployments. Copy this file to appsettings.json and fill in real values. Never commit appsettings.Development.json."
}
